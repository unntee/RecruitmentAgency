<Window x:Class="RecruitmentAgency.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RecruitmentAgency"
        mc:Ignorable="d"
        Title="AddWindow" Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel>
        <TextBlock Text="Название вакансии"/>
        <TextBox x:Name="VacTB" GotFocus="TextBox_GotFocus"/>
        <TextBlock Text="Компания"/>
        <TextBox x:Name="ComTB" GotFocus="TextBox_GotFocus"/>
        <TextBlock Text="Зарплата от"/>
        <TextBox x:Name="MinZpTB" GotFocus="TextBox_GotFocus"/>
        <TextBlock Text="Зарплата до"/>
        <TextBox x:Name="MaxZpTB" GotFocus="TextBox_GotFocus"/>
        <TextBlock Text="Требования"/>
        <TextBox x:Name="TrebTB" GotFocus="TextBox_GotFocus"/>
        <TextBlock Text="Статус"/>
        <TextBox x:Name="StatTB" GotFocus="TextBox_GotFocus"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button Content="Сохранить"
                    Click="SaveButton_Click"
                    x:Name="SaveButton"
                    IsDefault="True"/>
            <Button Content="Отмена"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
