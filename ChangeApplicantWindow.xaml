<Window x:Class="RecruitmentAgency.ChangeApplicantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RecruitmentAgency"
        mc:Ignorable="d"
        Title="ChangeApplicantWindow" Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel>
        <TextBlock Text="Редактирование анкеты соискателя"
               HorizontalAlignment="Center"/>
        <StackPanel>
            <TextBlock Text="ФИО соискателя "/>
            <TextBox Name="NameTB" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text="Возраст"/>
            <TextBox Name="AgeTB" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text="Образование"/>
            <TextBox Name="EduTB" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text="Опыт работы (лет)"/>
            <TextBox Name="ExpTB" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text="Контакты"/>
            <TextBox Name="ContactsTB" GotFocus="TextBox_GotFocus"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Сохранить"
                    Click="SaveButton_Click"
                    x:Name="SaveButton"
                    IsDefault="True"/>
            <Button Content="Отмена"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
